            "state": "translated",
            "value": "Блокирует взаимодействие этого аккаунта с вами"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blokuje temu kontu możliwość interakcji z Tobą"
          }
        },
        "pt": {
