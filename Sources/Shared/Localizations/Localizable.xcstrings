        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aviso: isso bloqueará todos os seguidores desta conta. Use com cuidado."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경고: 이렇게 하면 이 계정의 모든 팔로어가 차단됩니다. 주의해서 사용하세요."
