      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止此帐户与您互动"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hesabın sizinle etkileşimde bulunmasını engeller"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blokkeert de interactie van dit account met u"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントがあなたとやり取りできないようにブロックします"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blockiert die Interaktion dieses Kontos mit Ihnen"
          }
