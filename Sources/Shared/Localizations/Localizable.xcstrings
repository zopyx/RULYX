          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette sélection n'affecte pas votre compte actif — vous pouvez être connecté à un compte pour naviguer et utiliser un compte différent pour les recherches. Votre compte actif est utilisé pour toutes les actions de modération comme le blocage, la mise en sourdine et la gestion des listes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa selezione non influisce sul tuo account attivo — puoi essere connesso a un account per navigare e utilizzare un account diverso per le ricerche. Il tuo account attivo viene utilizzato per tutte le azioni di moderazione come bloccare, silenziare e gestire le liste."
          }
        },
        "ja" : {
