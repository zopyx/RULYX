    "account.preferred_search.info.p1": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "The search account determines which Bluesky account is used when performing searches across the app. All moderation actions, profile lookups, and timeline searches will be executed from this account perspective."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "The search account determines which Bluesky account is used when performing searches across the app. All moderation actions, profile lookups, and timeline searches will be executed from this account perspective."
