    "list.detail.subscribe.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "将此审核列表添加到您的帐户，以便其规则适用于您"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurallarının sizin için geçerli olması için bu denetleme listesini hesabınıza ekleyin"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg deze moderatielijst toe aan uw account, zodat de regels op u van toepassing zijn"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このモデレーション リストをアカウントに追加すると、そのルールが適用されます"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie diese Moderationsliste Ihrem Konto hinzu, damit die Regeln für Sie gelten"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте этот список модерации в свою учетную запись, чтобы его правила распространялись на вас."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj tę listę moderacji do swojego konta, aby jej zasady miały zastosowanie do Ciebie"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione esta lista de moderação à sua conta para que as regras se apliquem a você"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add this moderation list to your account so its rules apply to you"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi questo elenco di moderazione al tuo account in modo che le sue regole si applichino a te"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez cette liste de modération à votre compte pour que ses règles s'appliquent à vous"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "규칙이 귀하에게 적용되도록 이 조정 목록을 계정에 추가하세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm danh sách kiểm duyệt này vào tài khoản của bạn để các quy tắc của nó áp dụng cho bạn"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มรายการตรวจสอบนี้ลงในบัญชีของคุณเพื่อให้กฎของรายการมีผลกับคุณ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregue esta lista de moderación a su cuenta para que sus reglas se apliquen a usted"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف قائمة الإشراف هذه إلى حسابك حتى تنطبق قواعدها عليك"
          }
        }
      }
    },
    "list.detail.subscribe.hint": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅此审核列表"
          }
        },
        "tr": {
