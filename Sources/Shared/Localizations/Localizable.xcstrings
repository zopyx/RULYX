          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ostrzeżenie: spowoduje to zablokowanie każdego obserwującego to konto. Używaj ostrożnie."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uyarı: Bu, bu hesabın tüm takipçilerini engelleyecektir. Dikkatli kullanın."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำเตือน: วิธีนี้จะบล็อกผู้ติดตามทุกคนของบัญชีนี้ ใช้ด้วยความระมัดระวัง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cảnh báo: Điều này sẽ chặn mọi người theo dõi tài khoản này. Sử dụng một cách thận trọng."
          }
        }
      }
