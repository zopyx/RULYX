    "account.preferred_search.info.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The search account determines which Bluesky account is used when performing searches across the app. All moderation actions, profile lookups, and timeline searches will be executed from this account perspective."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Suchkonto bestimmt, welches Bluesky-Konto für Suchanfragen in der App verwendet wird. Alle Moderationsaktionen, Profilabfragen und Timeline-Suchen werden aus der Perspektive dieses Kontos ausgeführt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The search account determines which Bluesky account is used when performing searches across the app. All moderation actions, profile lookups, and timeline searches will be executed from this account perspective."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The search account determines which Bluesky account is used when performing searches across the app. All moderation actions, profile lookups, and timeline searches will be executed from this account perspective."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le compte de recherche détermine quel compte Bluesky est utilisé lors des recherches dans l'application. Toutes les actions de modération, les consultations de profil et les recherches dans le fil d'actualité seront exécutées depuis la perspective de ce compte."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'account di ricerca determina quale account Bluesky viene utilizzato per eseguire ricerche nell'app. Tutte le azioni di moderazione, le ricerche di profili e le ricerche nella timeline verranno eseguite dalla prospettiva di questo account."
          }
        },
        "ja" : {
          "stringUnit" : {
