    "lists.moderation_lists.help" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتيح لك قوائم الإشراف إمكانية كتم الحسابات بشكل مجمّع أو حظرها بشكل مجمّع معًا. اضغط على + لإنشاء واحدة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit Moderationslisten können Sie Konten gemeinsam stummschalten oder sperren.Tippen Sie auf +, um eines zu erstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moderation lists let you bulk-mute or bulk-block accounts together. Tap + to create one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las listas de moderación le permiten silenciar o bloquear cuentas en masa juntas. Toca + para crear uno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les listes de modération vous permettent de désactiver ou de bloquer en masse des comptes ensemble. Appuyez sur + pour en créer un."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli elenchi di moderazione ti consentono di disattivare o bloccare collettivamente gli account insieme. Tocca + per crearne uno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデレーションリストを使用すると、アカウントをまとめて一括ミュートまたは一括ブロックできます。 + をタップして作成します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "검토 목록을 사용하면 계정을 일괄 음소거하거나 일괄 차단할 수 있습니다. +를 탭하여 계정을 만드세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met moderatielijsten kunt u accounts samen bulksgewijs dempen of bulksgewijs blokkeren. Tik op + om er een te maken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Listy moderacji umożliwiają zbiorcze wyciszanie lub zbiorcze blokowanie kont. Kliknij +, aby go utworzyć."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As listas de moderação permitem silenciar ou bloquear contas em massa em conjunto. Toque em + para criar um."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Списки модерации позволяют одновременно отключать или блокировать учетные записи. Нажмите +, чтобы создать его."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "รายการตรวจสอบช่วยให้คุณปิดเสียงหรือบล็อกบัญชีจำนวนมากพร้อมกันได้ แตะ + เพื่อสร้าง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Denetleme listeleri, hesapları toplu olarak sessize almanıza veya toplu olarak engellemenize olanak tanır. Bir tane oluşturmak için +'ya dokunun."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Danh sách kiểm duyệt cho phép bạn tắt tiếng hàng loạt hoặc chặn hàng loạt tài khoản cùng nhau. Nhấn vào + để tạo một cái."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "审核列表可让您一起批量静音或批量阻止帐户。点击 + 创建一个。"
          }
        }
      }
    },
