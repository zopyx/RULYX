    "lists.advanced.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search for posts mentioning your handle or run custom searches across Bluesky."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Suchen Sie nach Beiträgen, in denen Ihr Benutzername erwähnt wird, oder führen Sie benutzerdefinierte Suchvorgänge in Bluesky durch."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherchez des publications mentionnant votre pseudo ou effectuez des recherches personnalisées sur Bluesky."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerca post che menzionano il tuo pseudonimo o esegui ricerche personalizzate su Bluesky."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分のハンドルに言及した投稿を検索するか、Bluesky 全体でカスタム検索を実行します。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索提及您的账号的帖子或在 Bluesky 中运行自定义搜索。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busque publicaciones que mencionen su nombre de usuario o realice búsquedas personalizadas en Bluesky."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pesquise postagens que mencionem seu nome de usuário ou faça pesquisas personalizadas no Bluesky."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "귀하의 핸들을 언급하는 게시물을 검색하거나 Bluesky에서 맞춤 검색을 실행하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ищите сообщения, в которых упоминается ваш псевдоним, или выполняйте индивидуальный поиск в Bluesky."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابحث عن المنشورات التي تشير إلى اسمك أو قم بإجراء عمليات بحث مخصصة عبر Bluesky."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoek naar berichten waarin jouw gebruikersnaam wordt vermeld of voer aangepaste zoekopdrachten uit in Bluesky."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Szukaj postów wspominających Twój nick lub przeprowadzaj niestandardowe wyszukiwania w Bluesky."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanıcı adınızdan bahseden gönderileri arayın veya Bluesky'de özel aramalar yapın."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ค้นหาโพสต์ที่กล่าวถึงหมายเลขอ้างอิงของคุณหรือดำเนินการค้นหาที่กำหนดเองใน Bluesky"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tìm kiếm các bài đăng đề cập đến tên người dùng của bạn hoặc chạy các tìm kiếm tùy chỉnh trên Bluesky."
          }
        }
      }
    },
