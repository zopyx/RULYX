    "settings.icloud.privacy.message": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "帐户句柄、显示名称和PDS URL将通过iCloud以明文形式在您的设备间同步。应用密码保留在设备上。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanıcı adları, görünen adlar ve PDS URL'leri iCloud üzerinden cihazlarınız arasında düz metin olarak senkronize edilir. Uygulama şifreleri cihazda kalır."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Handles, weergavenamen en PDS-URL's worden als platte tekst gesynchroniseerd via iCloud tussen uw apparaten. App-wachtwoorden blijven op het apparaat."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハンドル、表示名、PDS URLはiCloud経由でデバイス間で平文のまま同期されます。アプリパスワードはデバイス上に残ります。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Account-Handles, Anzeigenamen und PDS-URLs werden im Klartext über iCloud auf Ihren Geräten synchronisiert. App-Passwörter bleiben auf dem Gerät."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Идентификаторы, отображаемые имена и URL-адреса PDS будут синхронизированы в открытом виде через iCloud между вашими устройствами. Пароли приложений остаются на устройстве."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Identyfikatory, nazwy wyświetlane i adresy URL PDS będą synchronizowane w postaci zwykłego tekstu przez iCloud między urządzeniami. Hasła aplikacji pozostają na urządzeniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Handles, nomes de exibição e URLs de PDS serão sincronizados em texto simples via iCloud entre seus dispositivos. As senhas de aplicativo permanecem no dispositivo."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Account handles, display names, and PDS URLs will be synced across your devices via iCloud in cleartext. App passwords remain on-device."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Handle, nomi visualizzati e URL PDS verranno sincronizzati in chiaro tramite iCloud tra i tuoi dispositivi. Le password delle app rimangono sul dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les identifiants, noms d'affichage et URL PDS seront synchronisés en texte clair via iCloud sur vos appareils. Les mots de passe d'application restent sur l'appareil."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "핸들, 표시 이름 및 PDS URL이 iCloud를 통해 기기 간에 일반 텍스트로 동기화됩니다. 앱 비밀번호는 기기에 남아 있습니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tên người dùng, tên hiển thị và URL PDS sẽ được đồng bộ dưới dạng văn bản thuần qua iCloud giữa các thiết bị của bạn. Mật khẩu ứng dụng vẫn ở trên thiết bị."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ชื่อผู้ใช้ ชื่อที่แสดง และ URL PDS จะถูกซิงค์เป็นข้อความธรรมดาผ่าน iCloud ระหว่างอุปกรณ์ของคุณ รหัสผ่านแอปจะยังคงอยู่ในอุปกรณ์"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los handles, nombres para mostrar y URL de PDS se sincronizarán en texto plano a través de iCloud entre sus dispositivos. Las contraseñas de aplicación permanecen en el dispositivo."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم مزامنة أسماء المستخدمين والأسماء المعروضة وعناوين URL الخاصة بـ PDS كنص واضح عبر iCloud عبر أجهزتك. تبقى كلمات مرور التطبيق على الجهاز."
          }
        }
      }
    },
