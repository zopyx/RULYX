            "value": "このプロファイルに従うすべてのアカウントをブロックします — バックグラウンド アクションとしてキューに入れられます"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止遵循此配置文件的每个帐户 - 作为后台操作排队"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloquea todas las cuentas que siguen este perfil (en cola como acción en segundo plano)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloqueia todas as contas que seguem este perfil – na fila como uma ação em segundo plano"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 프로필을 따르는 모든 계정을 차단합니다. 백그라운드 작업으로 대기 중입니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Блокирует каждую учетную запись, которая следует за этим профилем — ставится в очередь как фоновое действие."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحظر كل حساب يتبع ملف التعريف هذا — ويتم وضعه في قائمة الانتظار كإجراء في الخلفية"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blokkeert elk account dat dit profiel volgt – in de wachtrij geplaatst als achtergrondactie"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blokuje każde konto, które obserwuje ten profil — umieszczone w kolejce jako akcja w tle"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu profili takip eden tüm hesapları engeller; arka plan işlemi olarak sıraya alınır"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บล็อกทุกบัญชีที่ติดตามโปรไฟล์นี้ — จัดคิวเป็นการดำเนินการเบื้องหลัง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chặn mọi tài khoản theo dõi hồ sơ này — được xếp hàng dưới dạng hành động nền"
          }
        }
      }
    },
    "profile.block_all_warning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
