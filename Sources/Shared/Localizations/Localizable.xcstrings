        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロファイルに従うすべてのアカウントをブロックします — バックグラウンド アクションとしてキューに入れられます"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blockiert jedes Konto, das diesem Profil folgt – als Hintergrundaktion in die Warteschlange gestellt"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Блокирует каждую учетную запись, которая следует за этим профилем — ставится в очередь как фоновое действие."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blokuje każde konto, które obserwuje ten profil — umieszczone w kolejce jako akcja w tle"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloqueia todas as contas que seguem este perfil – na fila como uma ação em segundo plano"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocks every account that follows this profile — queued as a background action"
          }
        },
        "it": {
