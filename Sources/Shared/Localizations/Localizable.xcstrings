    "list.detail.subscribe.desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف قائمة الإشراف هذه إلى حسابك حتى تنطبق قواعدها عليك"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügen Sie diese Moderationsliste Ihrem Konto hinzu, damit die Regeln für Sie gelten"
