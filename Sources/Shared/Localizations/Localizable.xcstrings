    "account.preferred_search.info.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This selection does not affect your active account — you can be signed into one account for browsing and use a different account for searches. Your active account is used for all moderation actions like blocking, muting, and list management."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Auswahl hat keinen Einfluss auf Ihr aktives Konto — Sie können mit einem Konto angemeldet sein und ein anderes für Suchanfragen verwenden. Ihr aktives Konto wird für alle Moderationsaktionen wie Blockieren, Stummschalten und Listenverwaltung verwendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This selection does not affect your active account — you can be signed into one account for browsing and use a different account for searches. Your active account is used for all moderation actions like blocking, muting, and list management."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
