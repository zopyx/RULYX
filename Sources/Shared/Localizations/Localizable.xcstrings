    "post.delete.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently remove the post from Bluesky. This cannot be undone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird der Beitrag dauerhaft aus Bluesky entfernt.Dies kann nicht rückgängig gemacht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera définitivement la publication de Bluesky. Cela ne peut pas être annulé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciò rimuoverà permanentemente il post da Bluesky. Questa operazione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、投稿は Bluesky から永久に削除されます。これを元に戻すことはできません。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从 Bluesky 中永久删除该帖子。此操作无法撤消。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente la publicación de Bluesky. Esto no se puede deshacer."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso removerá permanentemente a postagem do Bluesky. Isto não pode ser desfeito."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그러면 Bluesky에서 게시물이 영구적으로 제거됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это приведет к удалению публикации из Bluesky. Это невозможно отменить."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى إزالة المنشور نهائيًا من Bluesky. لا يمكن التراجع عن هذا."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdoor wordt het bericht definitief van Bluesky verwijderd. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to trwałe usunięcie posta z Bluesky. Tego nie można cofnąć."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, gönderiyi Bluesky'den kalıcı olarak kaldıracaktır. Bu geri alınamaz."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบโพสต์ออกจาก Bluesky อย่างถาวร สิ่งนี้ไม่สามารถยกเลิกได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Điều này sẽ xóa vĩnh viễn bài đăng khỏi Bluesky. Điều này không thể hoàn tác được."
          }
        }
      }
    },
