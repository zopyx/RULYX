          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำเตือน: วิธีนี้จะบล็อกผู้ติดตามทุกคนของบัญชีนี้ ใช้ด้วยความระมัดระวัง"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: esto bloqueará a todos los seguidores de esta cuenta. Úselo con precaución."
          }
        },
