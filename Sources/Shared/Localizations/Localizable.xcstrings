    "account.preferred_search.info.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose an account with minimal blocks and mutes to get the broadest search results. Accounts with many blocks may not discover certain profiles or content due to their block list."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie ein Konto mit möglichst wenigen Blockierungen und Stummschaltungen, um die breitesten Suchergebnisse zu erhalten. Konten mit vielen Blockierungen können aufgrund ihrer Blockierliste möglicherweise bestimmte Profile oder Inhalte nicht finden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose an account with minimal blocks and mutes to get the broadest search results. Accounts with many blocks may not discover certain profiles or content due to their block list."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose an account with minimal blocks and mutes to get the broadest search results. Accounts with many blocks may not discover certain profiles or content due to their block list."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez un compte avec un minimum de blocages et de silences pour obtenir les résultats de recherche les plus larges. Les comptes avec de nombreux blocages peuvent ne pas découvrir certains profils ou contenus en raison de leur liste de blocage."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli un account con il minor numero di blocchi e silenziamenti per ottenere i risultati di ricerca più ampi. Gli account con molti blocchi potrebbero non scoprire determinati profili o contenuti a causa della loro lista di blocchi."
          }
        },
        "ja" : {
          "stringUnit" : {
