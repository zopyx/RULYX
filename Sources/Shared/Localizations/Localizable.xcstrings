{
  "sourceLanguage" : "en",
  "strings" : {
    "@%@" : {
      "comment" : "A label displaying a user's handle. The argument is the user's handle.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "A badge that shows the number of unread messages in a conversation.",
      "isCommentAutoGenerated" : true
    },
    "%@ (%@)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ (%2$@)"
          }
        }
      }
    },
    "%@ / %@" : {
      "comment" : "A badge showing the current image index and total image count.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ / %2$@"
          }
        }
      }
    },
    "%@ completed" : {
      "comment" : "A label that indicates that a pending action has completed.",
      "isCommentAutoGenerated" : true
    },
    "%@ members" : {
      "comment" : "A label showing the number of members in a list. The argument is the number of members in the list.",
      "isCommentAutoGenerated" : true
    },
    "%@ of %@%@" : {
      "comment" : "A progress bar with a label showing the current progress of a long-running action. The first argument is the number of completed steps. The second argument is the total number of steps. The third argument is an optional suffix that provides additional context about the action.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ of %2$@%3$@"
          }
        }
      }
    },
    "%@ succeeded, %@ failed" : {
      "comment" : "A message that shows the number of actions that succeeded and failed.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ succeeded, %2$@ failed"
          }
        }
      }
    },
    "%@/%@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@/%2$@"
          }
        }
      }
    },
    "%@/%@ resolved" : {
      "comment" : "A label showing the number of resolved and unresolved results. The first argument is the number of resolved results. The second argument is the total number of results.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@/%2$@ resolved"
          }
        }
      }
    },
    "%@/300" : {

    },
    "%@x" : {
      "comment" : "A count of how many times a given account was used in moderation.",
      "isCommentAutoGenerated" : true
    },
