    "lists.relationships.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View your followers, who you follow, accounts you block, and accounts that block you."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sehen Sie sich Ihre Follower an, wem Sie folgen, Konten, die Sie blockieren, und Konten, die Sie blockieren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affichez vos abonnés, les personnes que vous suivez, les comptes que vous bloquez et les comptes qui vous bloquent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualizza i tuoi follower, chi segui, gli account che blocchi e gli account che ti bloccano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのフォロワー、あなたがフォローしている人、あなたがブロックしているアカウント、あなたをブロックしているアカウントを表示します。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "查看您的关注者、您关注的人、您阻止的帐户以及阻止您的帐户。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vea sus seguidores, a quién sigue, las cuentas que bloquea y las cuentas que lo bloquean."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja seus seguidores, quem você segue, contas que você bloqueia e contas que bloqueiam você."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팔로어, 팔로우하는 사람, 차단한 계정, 차단한 계정을 확인하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте своих подписчиков, на которых вы подписаны, учетные записи, которые вы блокируете, и учетные записи, которые блокируют вас."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عرض متابعيك، ومن تتابعهم، والحسابات التي تحظرها، والحسابات التي تحظرك."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekijk uw volgers, wie u volgt, accounts die u blokkeert en accounts die u blokkeren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyświetl swoich obserwujących, osoby, które obserwujesz, konta, które blokujesz i konta, które blokują Ciebie."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takipçilerinizi, takip ettiğiniz kişileri, engellediğiniz hesapları ve sizi engelleyen hesapları görüntüleyin."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ดูผู้ติดตามของคุณ คนที่คุณติดตาม บัญชีที่คุณบล็อก และบัญชีที่บล็อกคุณ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xem những người theo dõi bạn, những người bạn theo dõi, những tài khoản bạn chặn và những tài khoản chặn bạn."
          }
        }
      }
    },
