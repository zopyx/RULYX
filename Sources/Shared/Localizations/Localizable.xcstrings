    "lists.lists.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regular lists organize accounts for reference without moderation actions."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Regelmäßige Listen organisieren Konten als Referenz ohne Moderationsmaßnahmen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les listes régulières organisent les comptes pour référence sans actions de modération."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli elenchi regolari organizzano gli account per riferimento senza azioni di moderazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常のリストでは、モデレート アクションを行わずに参照用にアカウントを整理します。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "常规列表会整理帐户以供参考，无需进行审核操作。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las listas periódicas organizan cuentas para referencia sin acciones de moderación."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Listas regulares organizam contas para referência sem ações de moderação."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일반 목록은 조정 작업 없이 참조용으로 계정을 구성합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обычные списки организуют учетные записи для справки без действий модерации."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقوم القوائم العادية بتنظيم الحسابات كمرجع دون إجراءات الاعتدال."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Regelmatige lijsten organiseren accounts ter referentie zonder moderatie-acties."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Regularne listy organizują konta w celach informacyjnych bez działań moderacyjnych."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Normal listeler, hesapları denetleme eylemleri olmadan referans amacıyla düzenler."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายการปกติจะจัดระเบียบบัญชีเพื่อใช้อ้างอิงโดยไม่ต้องดำเนินการกลั่นกรอง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Danh sách thông thường sắp xếp các tài khoản để tham khảo mà không cần thực hiện hành động kiểm duyệt."
          }
        }
      }
    },
