            "state": "new",
            "value": "%1$@/%2$@"
          }
        }
      }
    },
    "%@/300": {},
    "%@x": {
      "comment": "A count of how many times a given account was used in moderation.",
      "isCommentAutoGenerated": true
    },
    "@%@": {
      "comment": "A label displaying a user's handle. The argument is the user's handle.",
      "isCommentAutoGenerated": true
    },
