    "account.add.password_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app stores the password securely in the iOS Keychain and uses it for Bluesky account access."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App speichert das Passwort sicher in der iOS Keychain und verwendet es für den Bluesky-Zugriff."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application stocke le mot de passe en toute sécurité dans le Keychain iOS et l'utilise pour l'accès Bluesky."
