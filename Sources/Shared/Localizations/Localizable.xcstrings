    "list.compare.help_tooltip": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "将此列表与另一个列表进行比较。查看重叠和唯一的成员，然后在列表之间复制或移动成员。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu listeyi başka bir listeyle karşılaştırın. Çakışan ve benzersiz üyeleri görüntüleyin, ardından üyeleri listeler arasında kopyalayın veya taşıyın."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vergelijk deze lijst met een andere lijst. Bekijk overlappende en unieke leden en kopieer of verplaats vervolgens leden tussen lijsten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリストを別のリストと比較します。重複する一意のメンバーを表示し、リスト間でメンバーをコピーまたは移動します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vergleichen Sie diese Liste mit einer anderen Liste.Zeigen Sie überlappende und eindeutige Mitglieder an und kopieren oder verschieben Sie dann Mitglieder zwischen Listen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сравните этот список с другим списком. Просматривайте пересекающиеся и уникальные элементы, а затем копируйте или перемещайте участников между списками."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Porównaj tę listę z inną listą. Przeglądaj nakładających się i unikalnych członków, a następnie kopiuj lub przenoś członków między listami."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare esta lista com outra lista. Visualize membros sobrepostos e exclusivos e copie ou mova membros entre listas."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare this list against another list. View overlapping and unique members, then copy or move members between lists."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Confronta questo elenco con un altro elenco. Visualizza membri sovrapposti e univoci, quindi copia o sposta i membri tra elenchi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparez cette liste avec une autre liste. Affichez les membres uniques et qui se chevauchent, puis copiez ou déplacez les membres entre les listes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 목록을 다른 목록과 비교하십시오. 겹치는 구성원과 고유한 구성원을 확인한 다음 목록 간에 구성원을 복사하거나 이동하세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "So sánh danh sách này với danh sách khác. Xem các thành viên chồng chéo và duy nhất, sau đó sao chép hoặc di chuyển các thành viên giữa các danh sách."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปรียบเทียบรายการนี้กับรายการอื่น ดูสมาชิกที่ทับซ้อนกันและไม่ซ้ำกัน จากนั้นคัดลอกหรือย้ายสมาชิกระหว่างรายการ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare esta lista con otra lista. Vea miembros únicos y superpuestos, luego copie o mueva miembros entre listas."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قارن هذه القائمة بقائمة أخرى. عرض الأعضاء المتداخلين والفريدين، ثم نسخ الأعضاء أو نقلهم بين القوائم."
          }
        }
      }
    },
