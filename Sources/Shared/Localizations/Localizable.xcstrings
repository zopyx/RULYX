    "settings.icloud.disabled_footer": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "启用以保持您的帐户配置在不同设备上保持一致。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesap yapılandırmanızın cihazlar arasında tutarlı kalmasını sağlamak için etkinleştirin."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel dit in om uw accountconfiguratie consistent te houden op alle apparaten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、デバイス間でアカウント設定の一貫性が保たれます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie diese Option, um Ihre Kontokonfiguration auf allen Geräten konsistent zu halten."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите, чтобы конфигурация вашей учетной записи была единообразной на всех устройствах."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz, aby zachować spójność konfiguracji konta na wszystkich urządzeniach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative para manter a configuração da sua conta consistente em todos os dispositivos."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable to keep your account configuration consistent across devices."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita per mantenere la configurazione del tuo account coerente su tutti i dispositivi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez cette option pour que la configuration de votre compte reste cohérente sur tous les appareils."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러 장치에서 계정 구성을 일관되게 유지하려면 활성화하세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bật để giữ cấu hình tài khoản của bạn nhất quán trên các thiết bị."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งานเพื่อให้การกำหนดค่าบัญชีของคุณสอดคล้องกันในอุปกรณ์ต่างๆ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilite esta opción para mantener la configuración de su cuenta consistente en todos los dispositivos."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالتمكين للحفاظ على اتساق تكوين حسابك عبر الأجهزة."
          }
        }
      }
    },
