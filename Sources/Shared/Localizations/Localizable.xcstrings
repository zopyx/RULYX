    "info.clearsky.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "屏蔽和被屏蔽数据由 ClearSky 提供。ClearSky 从 Bluesky 数据流索引屏蔽记录，并通过公共 API 提供。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required. (TR)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blockier- und Blockier-durch-Daten werden von ClearSky bereitgestellt. ClearSky indexiert Blockeinträge aus dem Bluesky-Firehose und stellt sie über eine öffentliche API bereit. (NL)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブロックデータはClearSkyによって提供されています。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blockier- und Blockier-durch-Daten werden von ClearSky bereitgestellt. ClearSky indexiert Blockeinträge aus dem Bluesky-Firehose und stellt sie über eine öffentliche API bereit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required. (RU)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required. (PL)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. Não authentication is required."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati di blocco sono forniti da ClearSky. ClearSky indicizza i record di blocco dal firehose Bluesky e li rende disponibili tramite API pubblica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
