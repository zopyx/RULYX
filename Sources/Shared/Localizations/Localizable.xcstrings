            "value" : "Authentifizieren Sie sich mit Ihren biometrischen Daten, um auf Ihre Konten und Moderationsdaten zuzugreifen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Authenticate with your biometrics to access your accounts and moderation data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autentícate con tus datos biométricos para acceder a tus cuentas y datos de moderación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Authentifiez-vous avec vos données biométriques pour accéder à vos comptes et données de modération."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autenticati con i tuoi dati biometrici per accedere ai tuoi account e ai dati di moderazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントとモデレーション データにアクセスするには、生体認証を使用して認証します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "귀하의 계정 및 중재 데이터에 액세스하려면 생체 인식으로 인증하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Authenticeer met uw biometrische gegevens om toegang te krijgen tot uw accounts en moderatiegegevens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwierzytelnij się za pomocą danych biometrycznych, aby uzyskać dostęp do swoich kont i danych moderacyjnych."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autentique-se com sua biometria para acessar suas contas e dados de moderação."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выполните аутентификацию с помощью биометрических данных, чтобы получить доступ к своим учетным записям и данным модерации."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ตรวจสอบสิทธิ์ด้วยไบโอเมตริกซ์ของคุณเพื่อเข้าถึงบัญชีและข้อมูลการกลั่นกรองของคุณ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesaplarınıza ve denetleme verilerinize erişmek için biyometrik bilgilerinizle kimlik doğrulaması yapın."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xác thực bằng sinh trắc học của bạn để truy cập vào tài khoản và dữ liệu kiểm duyệt của bạn."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用您的生物识别技术进行身份验证以访问您的帐户和审核数据。"
          }
        }
      }
