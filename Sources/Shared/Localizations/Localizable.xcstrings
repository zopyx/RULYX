    "account.preferred_search.info.p3": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "This selection does not affect your active account — you can be signed into one account for browsing and use a different account for searches. Your active account is used for all moderation actions like blocking, muting, and list management."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "This selection does not affect your active account — you can be signed into one account for browsing and use a different account for searches. Your active account is used for all moderation actions like blocking, muting, and list management."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "This selection does not affect your active account — you can be signed into one account for browsing and use a different account for searches. Your active account is used for all moderation actions like blocking, muting, and list management."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "This selection does not affect your active account — you can be signed into one account for browsing and use a different account for searches. Your active account is used for all moderation actions like blocking, muting, and list management."
          }
        },
        "de": {
          "stringUnit": {
