    "settings.icloud.disabled_footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بالتمكين للحفاظ على اتساق تكوين حسابك عبر الأجهزة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivieren Sie diese Option, um Ihre Kontokonfiguration auf allen Geräten konsistent zu halten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable to keep your account configuration consistent across devices."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilite esta opción para mantener la configuración de su cuenta consistente en todos los dispositivos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez cette option pour que la configuration de votre compte reste cohérente sur tous les appareils."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abilita per mantenere la configurazione del tuo account coerente su tutti i dispositivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、デバイス間でアカウント設定の一貫性が保たれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여러 장치에서 계정 구성을 일관되게 유지하려면 활성화하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schakel dit in om uw accountconfiguratie consistent te houden op alle apparaten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Włącz, aby zachować spójność konfiguracji konta na wszystkich urządzeniach."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ative para manter a configuração da sua conta consistente em todos os dispositivos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включите, чтобы конфигурация вашей учетной записи была единообразной на всех устройствах."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เปิดใช้งานเพื่อให้การกำหนดค่าบัญชีของคุณสอดคล้องกันในอุปกรณ์ต่างๆ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap yapılandırmanızın cihazlar arasında tutarlı kalmasını sağlamak için etkinleştirin."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bật để giữ cấu hình tài khoản của bạn nhất quán trên các thiết bị."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用以保持您的帐户配置在不同设备上保持一致。"
          }
        }
      }
    },
    "settings.icloud.enabled_footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتم مزامنة مقابض الحساب والتسميات عبر أجهزتك. تبقى كلمات مرور التطبيقات على كل جهاز لأغراض الأمان."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontonamen und -bezeichnungen werden auf Ihren Geräten synchronisiert.App-Passwörter bleiben aus Sicherheitsgründen auf jedem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Account handles and labels sync across your devices. App passwords stay on each device for security."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los identificadores y etiquetas de cuenta se sincronizan en todos sus dispositivos. Las contraseñas de las aplicaciones permanecen en cada dispositivo por seguridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les identifiants et étiquettes de compte sont synchronisés sur vos appareils. Les mots de passe des applications restent sur chaque appareil pour des raisons de sécurité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli handle e le etichette degli account si sincronizzano su tutti i tuoi dispositivi. Le password delle app rimangono su ciascun dispositivo per motivi di sicurezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウント ハンドルとラベルはデバイス間で同期されます。アプリのパスワードはセキュリティのために各デバイスに残ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 핸들과 라벨은 여러 기기에서 동기화됩니다. 보안을 위해 앱 비밀번호는 각 기기에 유지됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accounthandvatten en labels worden op al uw apparaten gesynchroniseerd. App-wachtwoorden blijven om veiligheidsredenen op elk apparaat staan."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uchwyty kont i etykiety synchronizują się na Twoich urządzeniach. Ze względów bezpieczeństwa hasła do aplikacji pozostają na każdym urządzeniu."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os identificadores e rótulos da conta são sincronizados em seus dispositivos. As senhas dos aplicativos permanecem em cada dispositivo por segurança."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Идентификаторы и ярлыки учетных записей синхронизируются на всех ваших устройствах. В целях безопасности пароли приложений сохраняются на каждом устройстве."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การจัดการบัญชีและป้ายกำกับจะซิงค์กับอุปกรณ์ของคุณ รหัสผ่านสำหรับแอปจะคงอยู่ในอุปกรณ์แต่ละเครื่องเพื่อความปลอดภัย"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap tanıtıcıları ve etiketleri cihazlarınız arasında senkronize edilir. Uygulama şifreleri güvenlik amacıyla her cihazda kalır."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các tài khoản và nhãn đồng bộ hóa trên các thiết bị của bạn. Mật khẩu ứng dụng được lưu giữ trên mỗi thiết bị để bảo mật."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "帐户句柄和标签在您的设备之间同步。为了安全起见，应用程序密码保留在每台设备上。"
          }
        }
      }
    },
