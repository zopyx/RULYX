    "info.keychain.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "账户机密数据永远不会离开您的设备。所有 API 调用直接发送到您的 Bluesky PDS。"
          }
        },
