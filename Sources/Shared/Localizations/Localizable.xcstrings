    "list.snapshot.help_tooltip" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تلتقط اللقطات العضوية الكاملة للقائمة في وقت ما. قارن بين لقطتين لمعرفة ما تغير."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapshots erfassen die vollständige Mitgliedschaft einer Liste zu einem bestimmten Zeitpunkt.Vergleichen Sie zwei Schnappschüsse, um zu sehen, was sich geändert hat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapshots capture the full membership of a list at a point in time. Compare two snapshots to see what changed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las instantáneas capturan todos los miembros de una lista en un momento dado. Compare dos instantáneas para ver qué cambió."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les instantanés capturent l’ensemble des membres d’une liste à un moment donné. Comparez deux instantanés pour voir ce qui a changé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le istantanee acquisiscono l'intera appartenenza a un elenco in un determinato momento. Confronta due istantanee per vedere cosa è cambiato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スナップショットは、ある時点でのリストの完全なメンバーシップをキャプチャします。 2 つのスナップショットを比較して、何が変更されたかを確認します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "스냅샷은 특정 시점에 목록의 전체 구성원을 캡처합니다. 두 개의 스냅샷을 비교하여 무엇이 변경되었는지 확인하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met momentopnamen wordt het volledige lidmaatschap van een lijst op een bepaald moment vastgelegd. Vergelijk twee snapshots om te zien wat er is veranderd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Migawki rejestrują pełne członkostwo na liście w danym momencie. Porównaj dwie migawki, aby zobaczyć, co się zmieniło."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os instantâneos capturam todos os membros de uma lista em um determinado momento. Compare dois instantâneos para ver o que mudou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Снимки фиксируют всех участников списка в определенный момент времени. Сравните два снимка, чтобы увидеть, что изменилось."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "สแนปชอตจะบันทึกความเป็นสมาชิกทั้งหมดของรายการ ณ เวลาใดเวลาหนึ่ง เปรียบเทียบสแนปชอตสองภาพเพื่อดูว่ามีอะไรเปลี่ยนแปลงไปบ้าง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anlık görüntüler, bir listenin belirli bir andaki tam üyeliğini yakalar. Neyin değiştiğini görmek için iki anlık görüntüyü karşılaştırın."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ảnh chụp nhanh ghi lại toàn bộ tư cách thành viên của danh sách tại một thời điểm. So sánh hai ảnh chụp nhanh để xem những gì đã thay đổi."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快照捕获列表在某个时间点的完整成员资格。比较两个快照以查看发生了什么变化。"
          }
        }
      }
    },
