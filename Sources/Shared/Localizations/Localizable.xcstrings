          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 프로필을 따르는 모든 계정을 차단합니다. 백그라운드 작업으로 대기 중입니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chặn mọi tài khoản theo dõi hồ sơ này — được xếp hàng dưới dạng hành động nền"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บล็อกทุกบัญชีที่ติดตามโปรไฟล์นี้ — จัดคิวเป็นการดำเนินการเบื้องหลัง"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloquea todas las cuentas que siguen este perfil (en cola como acción en segundo plano)"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحظر كل حساب يتبع ملف التعريف هذا — ويتم وضعه في قائمة الانتظار كإجراء في الخلفية"
          }
        }
      }
    },
    "profile.block_all_warning": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
