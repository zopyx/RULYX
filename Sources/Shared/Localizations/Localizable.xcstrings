    "info.feature.compare.compare": {
      "extractionState": "manual",
      "localizations": {
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "比较列表，查看重叠、仅在A和仅在B中的内容。"
          }
        },
        "tr": {
          "stringUnit": {
