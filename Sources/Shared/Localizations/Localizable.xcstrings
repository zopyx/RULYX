    "lock_screen.biometric_subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authenticate with {biometric} to access your accounts and moderation data."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifizieren Sie sich mit {biometric}, um auf Ihre Konten und Moderationsdaten zuzugreifen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifiez-vous avec {biometric} pour accéder à vos comptes et données de modération."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Autenticati con {biometric} per accedere ai tuoi account e ai dati di moderazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントとモデレーション データにアクセスするには、{biometric} で認証します。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "使用{biometric}进行身份验证以访问您的帐户和审核数据。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentícate con {biometric} para acceder a tus cuentas y datos de moderación."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentique-se com {biometric} para acessar suas contas e dados de moderação."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 및 조정 데이터에 액세스하려면 {biometric}으로 인증하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пройдите аутентификацию с помощью {biometric}, чтобы получить доступ к своим учетным записям и данным модерации."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالمصادقة باستخدام {biometric} للوصول إلى حساباتك وبيانات الإشراف."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Authenticeer met {biometric} om toegang te krijgen tot uw accounts en moderatiegegevens."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uwierzytelnij się za pomocą {biometric}, aby uzyskać dostęp do swoich kont i danych moderacyjnych."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesaplarınıza ve denetleme verilerinize erişmek için {biometric} ile kimlik doğrulaması yapın."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตรวจสอบสิทธิ์กับ {biometric} เพื่อเข้าถึงบัญชีและข้อมูลการกลั่นกรองของคุณ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xác thực bằng {biometric} để truy cập vào tài khoản và dữ liệu kiểm duyệt của bạn."
          }
        }
      }
    },
